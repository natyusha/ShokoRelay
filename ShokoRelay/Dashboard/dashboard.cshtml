<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard | Shoko Relay</title>
    <link rel="icon" href="favicon.ico" />
    <link rel="stylesheet" href="css/style.css" />
    <link rel="stylesheet" href="css/dashboard.css" />
    <script>
      window._sr = window._sr || {};
      window._sr.tasks = {
        plexCollectionsBuild: "{{TaskPlexCollectionsBuild}}",
        plexRatingsApply: "{{TaskPlexRatingsApply}}",
        vfsBuild: "{{TaskVfsBuild}}",
        shokoRemoveMissing: "{{TaskShokoRemoveMissing}}",
        atVfsBuild: "{{TaskAtVfsBuild}}",
        atMapBuild: "{{TaskAtMapBuild}}",
        atMp3Build: "{{TaskAtMp3Build}}",
      };
    </script>
  </head>

  <body>
    <div id="container">
      <div class="brand-header" role="img" aria-label="Shoko Relay Dashboard"></div>
      <!-- #region MARK: Plex
      -->
      <div class="two-cols">
        <section>
          <h2 class="plex">Plex: Authentication</h2>
          <div class="full" id="plex-auth-action">
            <!-- State: Unlinked -->
            <button id="plex-start" class="plex-auth-state">Start Plex Auth</button>
            <!-- State: Linked -->
            <div class="plex-auth-state full" hidden>
              <button id="plex-unlink" class="danger">Unlink Plex</button>
              <button id="plex-refresh" class="w46-button" title="Refresh Plex Libraries" data-relay-endpoint="/plex/auth/refresh" data-relay-method="POST" data-relay-label="Plex Discovery">
                <svg class="icon-svg"><use href="img/icons.svg#refresh"></use></svg>
              </button>
            </div>
          </div>
          <div class="full">
            <div>
              <label for="extra-plex-users">Extra Plex Users (<span id="plex-libraries-count">0</span> Libraries)</label>
              <input id="extra-plex-users" class="plex-auth" type="text" placeholder="user1;1234 (comma separated, optional PIN)" />
            </div>
            <div class="w46">
              <label for="plex-auto-frequency" title="Plex Automation Interval">Int.</label>
              <input id="plex-auto-frequency" class="plex-auth" type="number" min="0" step="1" placeholder="hrs" />
            </div>
          </div>
        </section>
        <section>
          <h2 class="plex">Plex: Automation</h2>
          <div class="full">
            <button id="{{ TaskPlexCollectionsBuild }}" class="plex-auth" data-relay-endpoint="/plex/collections/build" data-relay-label="Collections" data-relay-persist="true">Generate Collections</button>
            <button id="{{ TaskPlexRatingsApply }}" class="plex-auth" data-relay-endpoint="/plex/ratings/apply" data-relay-label="Critic Ratings" data-relay-persist="true">Apply Critic Ratings</button>
          </div>
          <hr class="plex-divider" />
          <div class="full">
            <label class="shoko-checkbox plex-auth">
              <input id="plex-scan-vfs" class="plex-auth" type="checkbox" />
              <span class="shoko-checkbox-icon" aria-hidden="true">
                <svg class="unchecked"><use href="img/icons.svg#checkbox-blank-circle-outline"></use></svg>
                <svg class="checked"><use href="img/icons.svg#checkbox-marked-circle-outline"></use></svg>
              </span>
              <span class="shoko-checkbox-text">
                <span class="shoko-checkbox-title">Force Partial Scans</span><br />
                <small>Trigger on VFS Change</small>
              </span>
            </label>
            <label class="shoko-checkbox">
              <input id="plex-scrobble" type="checkbox" />
              <span class="shoko-checkbox-icon" aria-hidden="true">
                <svg class="unchecked"><use href="img/icons.svg#checkbox-blank-circle-outline"></use></svg>
                <svg class="checked"><use href="img/icons.svg#checkbox-marked-circle-outline"></use></svg>
              </span>
              <span class="shoko-checkbox-text">
                <span class="shoko-checkbox-title">Auto Scrobble</span><br />
                <small>Plex Pass Webhook</small>
              </span>
            </label>
          </div>
        </section>
      </div>
      <!-- #endregion -->

      <!-- #region MARK: Shoko
      -->
      <div class="two-cols">
        <section>
          <div class="full">
            <h2>
              <svg class="icon-svg"><use href="img/icons.svg#database-refresh-outline"></use></svg>
              Shoko: VFS
            </h2>
            <a id="shoko-api-link" href="#" target="_blank" rel="noopener noreferrer" class="at-btn" title="Open Swagger" aria-label="Open Swagger">
              <svg class="icon-svg"><use href="img/icons.svg#api"></use></svg>
            </a>
          </div>
          <div class="full">
            <div>
              <label for="vfs-filter">Filter by SeriesID</label>
              <input id="vfs-filter" type="text" placeholder="comma separated; prefix 'a' for AniDB IDs" />
            </div>
          </div>
          <div class="full">
            <button id="{{ TaskVfsBuild }}" data-relay-endpoint="/vfs" data-relay-label="VFS Generation" data-relay-params="getVfsParams" data-relay-persist-if-empty="#vfs-filter">Generate</button>
            <button id="vfs-overrides" class="w46-button tmdb-ep-num" title="VFS Overrides Editor">
              <svg class="icon-svg"><use href="img/icons.svg#database-edit-outline"></use></svg>
            </button>
            <button id="vfs-clean" class="w46-button toggle" title="Clean VFS Toggle" aria-pressed="true" type="button">
              <svg class="icon-svg"><use href="img/icons.svg#broom"></use></svg>
            </button>
          </div>
        </section>
        <section>
          <div class="full">
            <h2>
              <svg class="icon-svg"><use href="img/icons.svg#auto-fix"></use></svg>
              Shoko: Automation
            </h2>
            <a id="shoko-dashboard-link" href="#" target="_blank" rel="noopener noreferrer" class="at-btn" title="Open Shoko Dashboard" aria-label="Open Shoko Dashboard">
              <svg class="icon-svg"><use href="img/icons.svg#view-dashboard-outline"></use></svg>
            </a>
          </div>
          <div class="full">
            <div>
              <label for="shoko-utc-offset">Schedule Offset</label>
              <input id="shoko-utc-offset" type="number" min="-12" max="14" step="1" placeholder="UTC (-12...+14)" />
            </div>
            <div class="w100">
              <label for="shoko-import-frequency" title="Automatic Source Import Interval">Import Int.</label>
              <input id="shoko-import-frequency" type="number" min="0" step="1" placeholder="hours" />
            </div>
            <div class="w100">
              <label for="shoko-sync-frequency" title="Automatic Watched State Sync Interval">Sync Int.</label>
              <input id="shoko-sync-frequency" class="plex-auth" type="number" min="0" step="1" placeholder="hours" />
            </div>
          </div>
          <div class="full">
            <button
              id="{{ TaskShokoRemoveMissing }}"
              title="Remove Missing Files From Shoko and MyList"
              data-relay-endpoint="/shoko/remove-missing?dryRun=false"
              data-relay-method="POST"
              data-relay-label="Remove Missing"
              data-relay-persist="true"
              data-relay-confirm="Are you sure you want to remove all records for missing files?<br><br><small>This will permanently remove them from Shoko's database and your AniDB MyList.</small>"
              data-relay-confirm-button="Remove Files"
            >
              Remove Missing
            </button>
            <div class="w100">
              <button id="shoko-import-run" title="Import From Source folders" data-relay-endpoint="/shoko/import" data-relay-method="POST" data-relay-label="Shoko Import">Import</button>
            </div>
            <div class="w100">
              <button id="shoko-sync-watched" class="plex-auth" title="Sync Watched States Menu">Sync</button>
            </div>
          </div>
        </section>
      </div>
      <!-- #endregion -->

      <!-- #region MARK: AnimeThemes
      -->
      <div class="two-cols">
        <section>
          <div class="full">
            <h2>
              <svg class="at-svg"><use href="img/icons.svg#animethemes"></use></svg>
              AnimeThemes: VFS
            </h2>
            <a href="player" target="_blank" rel="noopener noreferrer" class="at-btn" title="Open Video Player" aria-label="Open Video Player">
              <svg class="icon-svg"><use href="img/icons.svg#movie-open"></use></svg>
            </a>
          </div>
          <div class="full">
            <div>
              <label for="at-filter-map">Filter by SeriesID</label>
              <input id="at-filter-map" type="text" placeholder="comma separated; prefix 'a' for AniDB IDs" />
            </div>
          </div>
          <div class="full">
            <button
              id="{{ TaskAtVfsBuild }}"
              data-relay-endpoint="/animethemes/vfs/build"
              data-relay-label="AnimeThemes Generation"
              data-relay-params="getAtMapParams"
              data-relay-persist-if-empty="#at-filter-map"
            >
              Generate
            </button>
            <button id="at-map-import" class="w46-button" title="Import Curated Mapping File" data-relay-endpoint="/animethemes/vfs/import" data-relay-method="POST" data-relay-label="AnimeThemes Import">
              <svg class="icon-svg"><use href="img/icons.svg#download"></use></svg>
            </button>
            <button id="{{ TaskAtMapBuild }}" class="w46-button" title="Build Mapping File" data-relay-endpoint="/animethemes/vfs/map" data-relay-label="AnimeThemes Mapping" data-relay-persist="true">
              <svg class="icon-svg"><use href="img/icons.svg#sitemap"></use></svg>
            </button>
          </div>
        </section>
        <section id="at-mp3-section">
          <div id="at-progress-track" class="at-progress-track">
            <div id="at-progress-fill" class="at-progress-fill"></div>
          </div>
          <div class="full">
            <h2>
              <svg class="at-svg"><use href="img/icons.svg#animethemes"></use></svg>
              AnimeThemes: MP3
            </h2>
            <button id="at-play" class="at-btn" title="Play" type="button" aria-label="Play" hidden>
              <svg class="icon-svg play"><use href="img/icons.svg#play"></use></svg>
              <svg class="icon-svg next"><use href="img/icons.svg#skip-next"></use></svg>
            </button>
            <button id="at-mode" class="at-btn" title="Playback Mode" data-mode="loop" type="button" aria-label="Playback Mode" hidden>
              <svg class="icon-svg mode loop"><use href="img/icons.svg#sync"></use></svg>
              <svg class="icon-svg mode shuffle"><use href="img/icons.svg#shuffle-variant"></use></svg>
              <svg class="icon-svg mode off"><use href="img/icons.svg#sync-off"></use></svg>
            </button>
            <button id="at-playback" class="at-btn toggle" title="Playback Toggle" aria-pressed="false" type="button" aria-label="Playback Toggle">
              <svg class="icon-svg enabled"><use href="img/icons.svg#volume-high"></use></svg>
              <svg class="icon-svg disabled"><use href="img/icons.svg#volume-mute"></use></svg>
            </button>
          </div>
          <div class="full">
            <div class="at-path-col"><label>Path</label><input id="at-path" type="text" placeholder="Shoko or Plex relative anime path" /></div>
            <div class="w46"><label title="Preferred Theme">Slug</label><input id="at-slug" type="text" placeholder="OP2" /></div>
            <div class="w46"><label title="Index Override">Off.</label><input id="at-offset" type="number" value="" placeholder="0" /></div>
          </div>
          <div class="full">
            <button id="{{ TaskAtMp3Build }}" data-relay-action="atMp3Build">Generate</button>
            <button id="at-mp3-force" class="w46-button toggle" title="Force Overwrite Toggle" aria-pressed="false" type="button" aria-label="Force Overwrite Toggle">
              <svg class="icon-svg"><use href="img/icons.svg#chevron-triple-down"></use></svg>
            </button>
            <button id="at-mp3-batch" class="w46-button toggle" title="Recursive Batch Toggle" aria-pressed="false" type="button" aria-label="Recursive Batch Toggle">
              <svg class="icon-svg"><use href="img/icons.svg#file-tree"></use></svg>
            </button>
          </div>
        </section>
      </div>
      <!-- #endregion -->

      <!-- #region MARK: Provider Settings
      -->
      <section>
        <div class="full">
          <h2>
            <svg class="icon-svg"><use href="img/icons.svg#cog-outline"></use></svg>
            Provider Settings
          </h2>
          <button id="settings-help-open" class="at-btn" title="Settings Help" aria-label="Settings Help">
            <svg class="icon-svg"><use href="img/icons.svg#help-box"></use></svg>
          </button>
        </div>
        <div id="config-form"></div>
        <hr />
        <small>All provider settings are saved automatically</small>
      </section>
      <!-- #endregion -->
    </div>
    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>

    <!-- #region MARK: Floating Links
    -->
    <div class="floating-actions" role="navigation" aria-label="Quick links">
      <button id="theme-toggle" class="float-link theme-toggle" title="Theme Toggle" aria-label="Theme Toggle" aria-pressed="false">
        <svg class="icon-svg"><use href="img/icons.svg#theme-light-dark"></use></svg>
      </button>
      <a class="float-link" href="https://discord.gg/shokoanime" target="_blank" rel="noopener noreferrer" title="Discord" aria-label="Shoko Discord">
        <svg class="icon-svg"><use href="img/icons.svg#discord"></use></svg>
      </a>
      <a class="float-link" href="https://animethemes.moe/" target="_blank" rel="noopener noreferrer" title="AnimeThemes" aria-label="AnimeThemes">
        <svg class="at-svg"><use href="img/icons.svg#animethemes"></use></svg>
      </a>
      <a class="float-link" href="https://docs.shokoanime.com/" target="_blank" rel="noopener noreferrer" title="Shoko Docs" aria-label="Shoko Docs">
        <svg class="icon-svg"><use href="img/icons.svg#docs"></use></svg>
      </a>
      <a class="float-link github-float" href="https://github.com/natyusha/ShokoRelay" target="_blank" rel="noopener noreferrer" title="Github" aria-label="Shoko Relay on GitHub">
        <svg class="icon-svg"><use href="img/icons.svg#github"></use></svg>
      </a>
    </div>
    <!-- #endregion -->

    <!--#region MARK: Overrides Modal
    -->
    <div id="overrides-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
      <div class="modal overrides" role="document">
        <header>VFS Overrides Editor</header>
        <div class="modal-body">
          <textarea id="overrides-text"></textarea>
        </div>
        <footer>
          <button id="overrides-cancel" class="cancel">Cancel</button>
          <button id="overrides-save">Save</button>
        </footer>
      </div>
    </div>
    <!-- #endregion -->

    <!--#region MARK: Confirm Modal
    -->
    <div id="confirm-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
      <div class="modal confirmation" role="document">
        <header>Confirm Action</header>
        <div class="modal-body">
          <p id="confirm-message">Are you sure you wish to proceed?</p>
        </div>
        <footer>
          <button id="confirm-cancel" class="cancel">Cancel</button>
          <button id="confirm-exec" class="danger">Confirm</button>
        </footer>
      </div>
    </div>
    <!-- #endregion -->

    <!--#region MARK: Sync Watched Modal
    -->
    <div id="sync-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="sync-modal-title">
      <div class="modal" role="document">
        <header>Sync Watched States Menu</header>
        <div class="modal-body">
          <div class="full">
            <label class="dir-label">Direction<small></small></label>
            <button id="sync-direction-toggle" class="direction-toggle" aria-pressed="false" title="Toggle Direction" aria-label="Direction: Plex to Shoko">
              <span class="dir-label">Plex</span>
              <span id="sync-direction-arrow" class="dir-chevron">
                <svg id="dir-icon-right" class="dir-icon dir-icon-right" aria-hidden="true">
                  <use href="img/icons.svg#transfer-right"></use>
                </svg>
                <svg id="dir-icon-left" class="dir-icon dir-icon-left hidden" aria-hidden="true">
                  <use href="img/icons.svg#transfer-left"></use>
                </svg>
              </span>
              <span class="dir-label">Shoko</span>
            </button>
          </div>
          <hr />
          <small>The checkboxes below also apply to the webhook</small>
          <label class="shoko-checkbox">
            <input id="sync-ratings" type="checkbox" />
            <span class="shoko-checkbox-icon" aria-hidden="true">
              <svg class="unchecked"><use href="img/icons.svg#checkbox-blank-circle-outline"></use></svg>
              <svg class="checked"><use href="img/icons.svg#checkbox-marked-circle-outline"></use></svg>
            </span>
            <span class="shoko-checkbox-text"
              ><span class="shoko-checkbox-title">Include Ratings</span><br />
              <small>Sync user vote/rating values</small>
            </span>
          </label>
          <label class="shoko-checkbox">
            <input id="sync-exclude-admin" type="checkbox" />
            <span class="shoko-checkbox-icon" aria-hidden="true">
              <svg class="unchecked"><use href="img/icons.svg#checkbox-blank-circle-outline"></use></svg>
              <svg class="checked"><use href="img/icons.svg#checkbox-marked-circle-outline"></use></svg>
            </span>
            <span class="shoko-checkbox-text">
              <span class="shoko-checkbox-title">Exclude Admin</span><br />
              <small>Only sync to extra Plex users</small>
            </span>
          </label>
        </div>
        <footer>
          <button id="sync-cancel-button" class="cancel">Cancel</button>
          <button id="sync-start-button">Start Sync</button>
        </footer>
      </div>
    </div>
    <!-- #endregion -->

    <!--#region MARK: Settings Help Modal
  -->
    <div id="settings-help-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
      <div class="modal help" role="document">
        <header>Settings Help</header>
        <div class="modal-body">
          <section>
            <h3>Primary Settings</h3>
            <h4>Language Tag Examples</h4>
            <div class="full">
              <ul class="help-list">
                <li><code>SHOKO</code><small>Shoko's Preferred Title</small></li>
                <li><code>X-JAT</code><small>Romanized Japanese</small></li>
                <li><code>EN</code><small>English</small></li>
                <li><code>JA</code><small>Japanese</small></li>
                <li><code>ZH</code><small>Chinese</small></li>
                <li><code>KO</code><small>Korean</small></li>
              </ul>
              <ul class="help-list">
                <li><code>ES</code><small>Spanish</small></li>
                <li><code>FR</code><small>French</small></li>
                <li><code>PT</code><small>Portuguese</small></li>
                <li><code>RU</code><small>Russian</small></li>
                <li><code>DE</code><small>German</small></li>
                <li><code>IT</code><small>Italian</small></li>
              </ul>
            </div>
            <h4>Tag Weights</h4>
            <small>
              Many tags on AniDB use a <a href="https://wiki.anidb.net/Tags#Star-rating_-_the_Weight_system" target="_blank" rel="noopener noreferrer" title="AniDB Wiki">3 Star Weight System</a> which
              represents a value from 0 (no stars) to 600 (3 stars) and determines how relevant the tag is to the series it is applied to. By setting this value you can filter out tags below a certain star
              threshold.
            </small>
          </section>
          <section>
            <h3>Advanced Settings</h3>
            <h4>Path Mappings</h4>
            <small><em>Required if Plex and Shoko see your files via different paths</em></small>
            <ul class="help-list inline-help">
              <li><code>Left Column</code> <small>Plex Base Paths</small></li>
              <li><code>Right Column</code> <small>Shoko Base Paths</small></li>
            </ul>
            <h4>Path Exclusions</h4>
            <small>
              Allows specific folders within your Shoko managed destinations to be ignored during VFS generation. Any Shoko import folders that are not marked as a "Destination" as well as the: VFS Root Path,
              AnimeThemes Root Path and Collection Posters Root Path are excluded by default.
            </small>
            <h4>Plex Fixup Delay</h4>
            <small>
              Sometimes Shoko may not have acquired all of the metadata for a series when it is first scanned into Plex. This setting attempts to mitigate this by waiting for new files to be added to the VFS
              then triggering a delayed Plex metadata refresh. This action is debounced so adding multiple episodes within the configured delay will not trigger it multiple times.
            </small>
          </section>
        </div>
      </div>
    </div>
    <!-- #endregion -->

    <script src="js/script.js"></script>
    <script src="js/settings.js"></script>
    <script src="js/plex.js"></script>
    <script src="js/shoko.js"></script>
    <script src="js/animethemes.js"></script>
  </body>
</html>
