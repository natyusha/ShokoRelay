<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard | Shoko Relay</title>
    <link rel="icon" href="favicon.ico" />
    <link rel="stylesheet" href="css/style.css" />
  </head>

  <body>
    <div id="container">
      <div class="brand-header" role="img" aria-label="Shoko Relay Dashboard"></div>
      <!-- #region MARK: Plex
      -->
      <div class="full">
        <section>
          <h3 class="plex">Plex: Authentication</h3>
          <div class="full" id="plex-auth-action">
            <button id="plex-start">Start Plex Auth</button>
          </div>
          <div class="full">
            <div>
              <label for="extra-plex-users">Extra Plex Users (<span id="plex-libraries-count">0</span> Libraries)</label>
              <input id="extra-plex-users" class="plex-auth" type="text" placeholder="user1;1234 (comma separated, optional PIN)" />
            </div>
            <div class="w46">
              <label for="plex-auto-frequency" title="Plex Automation Interval">Int.</label>
              <input id="plex-auto-frequency" class="plex-auth" type="number" min="0" step="1" placeholder="hrs" />
            </div>
          </div>
        </section>
        <section>
          <h3 class="plex">Plex: Automation</h3>
          <div class="full">
            <button id="col-build" class="plex-auth">Generate Collections</button>
            <button id="rtg-build" class="plex-auth">Apply Critic Ratings</button>
          </div>
          <hr class="plex-divider" />
          <div class="full">
            <label class="shoko-checkbox plex-auth">
              <input id="plex-scan-vfs" class="plex-auth" type="checkbox" />
              <span class="shoko-checkbox-icon" aria-hidden="true">
                <svg class="unchecked">
                  <use href="img/icons.svg#checkbox-blank-circle-outline"></use>
                </svg>
                <svg class="checked">
                  <use href="img/icons.svg#checkbox-marked-circle-outline"></use>
                </svg>
              </span>
              <span class="shoko-checkbox-text">
                <span class="shoko-checkbox-title">Force Partial Scans</span><br />
                <small>Trigger on VFS Change</small>
              </span>
            </label>
            <label class="shoko-checkbox">
              <input id="plex-watched" type="checkbox" />
              <span class="shoko-checkbox-icon" aria-hidden="true">
                <svg class="unchecked">
                  <use href="img/icons.svg#checkbox-blank-circle-outline"></use>
                </svg>
                <svg class="checked">
                  <use href="img/icons.svg#checkbox-marked-circle-outline"></use>
                </svg>
              </span>
              <span class="shoko-checkbox-text">
                <span class="shoko-checkbox-title">Auto Scrobble</span><br />
                <small>Plex Pass Webhook</small>
              </span>
            </label>
          </div>
        </section>
      </div>
      <!-- #endregion -->

      <!-- #region MARK: Shoko
      -->
      <div class="full">
        <section>
          <h3>
            <svg class="icon-svg">
              <use href="img/icons.svg#database-refresh-outline"></use>
            </svg>
            Shoko: VFS
          </h3>
          <div class="full">
            <div>
              <label for="vfs-filter">Filter by ShokoSeriesID</label>
              <input id="vfs-filter" type="text" placeholder="comma separated" />
            </div>
          </div>
          <div class="full">
            <button id="vfs-exec">Generate</button>
            <button id="vfs-overrides" class="w46-button tmdb-ep-num" title="VFS Overrides Editor">
              <svg class="icon-svg">
                <use href="img/icons.svg#database-edit-outline"></use>
              </svg>
            </button>
            <button id="vfs-clean" class="w46-button toggle" title="Clean VFS Toggle" aria-pressed="true" type="button">
              <svg class="icon-svg">
                <use href="img/icons.svg#broom"></use>
              </svg>
            </button>
          </div>
        </section>
        <section>
          <h3>
            <svg class="icon-svg">
              <use href="img/icons.svg#auto-fix"></use>
            </svg>
            Shoko: Automation
          </h3>
          <div class="full">
            <div>
              <label for="shoko-utc-offset">Schedule Offset</label>
              <input id="shoko-utc-offset" type="number" min="-12" max="14" step="1" placeholder="UTC (-12...+14)" />
            </div>
            <div class="w100">
              <label for="shoko-import-frequency" title="Automatic Source Import Interval">Import Int.</label>
              <input id="shoko-import-frequency" type="number" min="0" step="1" placeholder="hours" />
            </div>
            <div class="w100">
              <label for="shoko-sync-frequency" title="Automatic Watched State Sync Interval">Sync Int.</label>
              <input id="shoko-sync-frequency" class="plex-auth" type="number" min="0" step="1" placeholder="hours" />
            </div>
          </div>
          <div class="full">
            <button id="shoko-remove-missing" class="danger" title="Removes Missing Files From Shoko and MyList">Remove Missing</button>
            <div class="w100">
              <button id="shoko-import-run" title="Import From Source folders">Import</button>
            </div>
            <div class="w100">
              <button id="shoko-sync-watched" class="plex-auth" title="Sync Watched States Menu">Sync</button>
            </div>
          </div>
        </section>
      </div>
      <!-- #endregion -->

      <!-- #region MARK: AnimeThemes
      -->
      <div class="full">
        <section>
          <div class="full">
            <h3>
              <svg class="at-svg">
                <use href="img/icons.svg#animethemes"></use>
              </svg>
              AnimeThemes: VFS
            </h3>
            <button id="at-webm-open" class="at-btn" title="Open Video Player" type="button" aria-label="Open Video Player">
              <svg class="icon-svg">
                <use href="img/icons.svg#movie-open"></use>
              </svg>
            </button>
          </div>
          <div class="full">
            <div>
              <label for="at-filter-map">Filter by ShokoSeriesID</label>
              <input id="at-filter-map" type="text" placeholder="comma separated" />
            </div>
          </div>
          <div class="full">
            <button id="at-apply">Generate</button>
            <button id="at-import" class="w46-button" title="Import Curated Mapping File">
              <svg class="icon-svg">
                <use href="img/icons.svg#download"></use>
              </svg>
            </button>
            <button id="at-mapping" class="w46-button" title="Build Mapping File">
              <svg class="icon-svg">
                <use href="img/icons.svg#sitemap"></use>
              </svg>
            </button>
          </div>
        </section>
        <section id="at-mp3-section">
          <div id="at-progress-track" class="at-progress-track">
            <div id="at-progress-fill" class="at-progress-fill"></div>
          </div>
          <div class="full">
            <h3>
              <svg class="at-svg">
                <use href="img/icons.svg#animethemes"></use>
              </svg>
              AnimeThemes: MP3
            </h3>
            <button id="at-play" class="at-btn" title="Play / Next" type="button" aria-label="Play / Next" hidden>
              <svg class="icon-svg play">
                <use href="img/icons.svg#play"></use>
              </svg>
              <svg class="icon-svg next">
                <use href="img/icons.svg#skip-next"></use>
              </svg>
            </button>
            <button id="at-mode" class="at-btn" title="Playback Mode" data-mode="loop" type="button" aria-label="Playback Mode" hidden>
              <svg class="icon-svg mode loop">
                <use href="img/icons.svg#sync"></use>
              </svg>
              <svg class="icon-svg mode shuffle">
                <use href="img/icons.svg#shuffle-variant"></use>
              </svg>
              <svg class="icon-svg mode off">
                <use href="img/icons.svg#sync-off"></use>
              </svg>
            </button>
            <button id="at-playback" class="at-btn toggle" title="Playback Toggle" aria-pressed="false" type="button" aria-label="Playback Toggle">
              <svg class="icon-svg enabled">
                <use href="img/icons.svg#volume-high"></use>
              </svg>
              <svg class="icon-svg disabled">
                <use href="img/icons.svg#volume-mute"></use>
              </svg>
            </button>
          </div>
          <div class="full">
            <div class="at-path-col"><label>Path</label><input id="at-path" type="text" placeholder="Shoko or Plex relative anime path" /></div>
            <div class="w46"><label title="Preferred Theme">Slug</label><input id="at-slug" type="text" placeholder="OP2" /></div>
            <div class="w46"><label title="Index Override">Off.</label><input id="at-offset" type="number" value="" placeholder="0" /></div>
          </div>
          <div class="full">
            <button id="at-single">Generate</button>
            <button id="at-force" class="w46-button toggle" title="Force Overwrite Toggle" aria-pressed="false" type="button" aria-label="Force Overwrite Toggle">
              <svg class="icon-svg">
                <use href="img/icons.svg#chevron-triple-down"></use>
              </svg>
            </button>
            <button id="at-batch" class="w46-button toggle" title="Recursive Batch Toggle" aria-pressed="false" type="button" aria-label="Recursive Batch Toggle">
              <svg class="icon-svg">
                <use href="img/icons.svg#file-tree"></use>
              </svg>
            </button>
          </div>
        </section>
      </div>
      <!-- #endregion -->

      <!-- #region MARK: Provider Settings
      -->
      <section>
        <h3>
          <svg class="icon-svg">
            <use href="img/icons.svg#cog-outline"></use>
          </svg>
          Provider Settings
        </h3>
        <div id="config-form"></div>
        <hr />
        <small>All provider settings are saved automatically</small>
      </section>
      <!-- #endregion -->
    </div>
    <div id="toast-container" aria-live="polite" aria-atomic="true"></div>

    <!-- #region MARK: Floating Links
    -->
    <div class="floating-actions" role="navigation" aria-label="Quick links">
      <button id="theme-toggle" class="float-link theme-toggle" aria-label="Toggle theme" aria-pressed="false">
        <svg class="icon-svg">
          <use href="img/icons.svg#theme-light-dark"></use>
        </svg>
      </button>
      <a class="float-link" href="https://discord.gg/shokoanime" target="_blank" rel="noopener noreferrer" aria-label="Shoko Discord">
        <svg class="icon-svg">
          <use href="img/icons.svg#discord"></use>
        </svg>
      </a>
      <a class="float-link" href="https://animethemes.moe/" target="_blank" rel="noopener noreferrer" aria-label="AnimeThemes">
        <svg class="at-svg">
          <use href="img/icons.svg#animethemes"></use>
        </svg>
      </a>
      <a class="float-link" href="https://docs.shokoanime.com/" target="_blank" rel="noopener noreferrer" aria-label="Shoko Docs">
        <svg class="icon-svg">
          <use href="img/icons.svg#docs"></use>
        </svg>
      </a>
      <a class="float-link github-float" href="https://github.com/natyusha/ShokoRelay" target="_blank" rel="noopener noreferrer" aria-label="Shoko Relay on GitHub">
        <svg class="icon-svg">
          <use href="img/icons.svg#github"></use>
        </svg>
      </a>
    </div>
    <!-- #endregion -->

    <!--#region MARK: Overrides Modal
    -->
    <div id="overrides-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
      <div class="modal overrides" role="document">
        <header>VFS Overrides Editor</header>
        <div class="modal-body">
          <textarea id="overrides-text"></textarea>
        </div>
        <footer>
          <button id="overrides-cancel" class="cancel">Cancel</button>
          <button id="overrides-save">Save</button>
        </footer>
      </div>
    </div>
    <!-- #endregion -->

    <!--#region MARK: Sync Watched Modal
    -->
    <div id="sync-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="sync-modal-title">
      <div class="modal" role="document">
        <header>Sync Watched States Menu</header>
        <div class="modal-body">
          <div class="full">
            <label class="dir-label">Direction<small></small></label>
            <button id="sync-direction-toggle" class="direction-toggle" aria-pressed="false" title="Toggle direction" aria-label="Direction: Plex to Shoko">
              <span class="dir-label">Plex</span>
              <span id="sync-direction-arrow" class="dir-chevron">
                <svg id="dir-icon-right" class="dir-icon dir-icon-right" aria-hidden="true">
                  <use href="img/icons.svg#transfer-right"></use>
                </svg>
                <svg id="dir-icon-left" class="dir-icon dir-icon-left hidden" aria-hidden="true">
                  <use href="img/icons.svg#transfer-left"></use>
                </svg>
              </span>
              <span class="dir-label">Shoko</span>
            </button>
          </div>
          <hr />
          <small>The checkboxes below also apply to the webhook</small>
          <label class="shoko-checkbox">
            <input id="sync-ratings" type="checkbox" />
            <span class="shoko-checkbox-icon" aria-hidden="true">
              <svg class="unchecked">
                <use href="img/icons.svg#checkbox-blank-circle-outline"></use>
              </svg>
              <svg class="checked">
                <use href="img/icons.svg#checkbox-marked-circle-outline"></use>
              </svg>
            </span>
            <span class="shoko-checkbox-text"
              ><span class="shoko-checkbox-title">Include Ratings</span><br />
              <small>Sync user vote/rating values</small>
            </span>
          </label>
          <label class="shoko-checkbox">
            <input id="sync-exclude-admin" type="checkbox" />
            <span class="shoko-checkbox-icon" aria-hidden="true">
              <svg class="unchecked">
                <use href="img/icons.svg#checkbox-blank-circle-outline"></use>
              </svg>
              <svg class="checked">
                <use href="img/icons.svg#checkbox-marked-circle-outline"></use>
              </svg>
            </span>
            <span class="shoko-checkbox-text">
              <span class="shoko-checkbox-title">Exclude Admin</span><br />
              <small>Only sync to extra Plex users</small>
            </span>
          </label>
        </div>
        <footer>
          <button id="sync-cancel-button" class="cancel">Cancel</button>
          <button id="sync-start-button">Start Sync</button>
        </footer>
      </div>
    </div>
    <!-- #endregion -->

    <!--#region MARK: Video Player Modal
    -->
    <div id="webm-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
      <div class="modal webm" role="document">
        <div class="modal-body">
          <video id="webm-video" controls></video>
          <div class="webm-controls">
            <button id="webm-next" class="at-btn" title="Next Theme" type="button" aria-label="Next Theme">
              <svg class="icon-svg">
                <use href="img/icons.svg#skip-next"></use>
              </svg>
            </button>
            <button id="webm-mode" class="at-btn" title="Playback Mode" data-mode="off" type="button" aria-label="Playback Mode">
              <svg class="icon-svg mode loop">
                <use href="img/icons.svg#sync"></use>
              </svg>
              <svg class="icon-svg mode shuffle">
                <use href="img/icons.svg#shuffle-variant"></use>
              </svg>
              <svg class="icon-svg mode next">
                <use href="img/icons.svg#shuffle-disabled"></use>
              </svg>
              <svg class="icon-svg mode off">
                <use href="img/icons.svg#sync-off"></use>
              </svg>
            </button>
            <span class="webm-filter-wrap">
              <svg class="icon-svg magnify-icon">
                <use href="img/icons.svg#magnify"></use>
              </svg>
              <input id="webm-filter" type="text" placeholder="Filter..." />
            </span>
          </div>
        </div>
        <details id="webm-tree-details" class="details-anim webm-tree-details">
          <summary>
            <span id="webm-now-playing" class="webm-now-playing">AnimeThemes: VFS Video Player</span>
          </summary>
          <hr />
          <div id="webm-tree" class="webm-tree details-content"></div>
        </details>
      </div>
    </div>
    <!-- #endregion -->

    <script src="js/script.js"></script>
    <script src="js/animethemes.js"></script>
  </body>
</html>
